{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach Deno Debug",
            "type": "node",
            "request": "attach",
            "address": "127.0.0.1",
            "port": 9229,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug Deno Tests",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeExecutable": "deno",
            "runtimeArgs": [
                "test",
                "-A",
                "--inspect-brk",
                "--unstable-kv",
                "tests/serie-service-test.ts"
            ],
            "attachSimplePort": 9229
        }
    ]
}
